# Right at Home BnB - Backend Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rightathome
DATABASE_POOL_SIZE=10

# JWT Authentication
JWT_SECRET=your-secure-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# OpenAI (AI Concierge)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4-turbo-preview

# ElevenLabs (Voice Service)
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Smart Lock Providers
SCHLAGE_API_KEY=your-schlage-api-key
YALE_API_KEY=your-yale-api-key
AUGUST_API_KEY=your-august-api-key

# Firebase
FIREBASE_PROJECT_ID=echo-prime-ai
FIREBASE_SERVICE_ACCOUNT=path/to/service-account.json

# CORS
CORS_ORIGINS=https://rightathome.vercel.app,http://localhost:3000

# Twilio (Optional - SMS/Voice)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+14325551234

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
