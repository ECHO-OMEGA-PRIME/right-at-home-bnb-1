{
  "name": "rightathome-bnb",
  "version": "1.0.0",
  "private": true,
  "description": "Right at Home BnB - Property Management System for Steven Palma's 22 Midland TX Rentals",
  "author": "ECHO OMEGA PRIME",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "web": "npm run dev --workspace=apps/web",
    "mobile": "npm run start --workspace=apps/mobile",
    "desktop": "npm run start --workspace=apps/desktop",
    "backend": "cd backend && python -m uvicorn main:app --reload --port 8000"
  },
  "dependencies": {
    "@prisma/client": "^5.9.0"
  },
  "devDependencies": {
    "prisma": "^5.9.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
