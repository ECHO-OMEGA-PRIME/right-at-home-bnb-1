# Right At Home BnB - Web Environment Variables
# Copy to .env.local and fill in values

# API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Firebase (Client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=echo-prime-ai.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=echo-prime-ai
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=echo-prime-ai.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=249995513427
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Admin SDK (Server-side) - REQUIRED for database features
# Get this from: Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
# Paste the ENTIRE JSON content as a single line (no line breaks)
# Example: {"type":"service_account","project_id":"echo-prime-ai","private_key_id":"xxx","private_key":"-----BEGIN PRIVATE KEY-----\n...","client_email":"firebase-adminsdk@echo-prime-ai.iam.gserviceaccount.com",...}
FIREBASE_SERVICE_ACCOUNT=paste_entire_json_here

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key

# AI Concierge (Steven)
NEXT_PUBLIC_AI_CONCIERGE_URL=http://localhost:8000/api/concierge

# Twilio (Optional - for phone/SMS alerts)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+14325551234
COMMANDER_PHONE=+14322693446
