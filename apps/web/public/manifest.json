{
  "name": "Right at Home BnB - Property Management",
  "short_name": "RAH BnB",
  "description": "Premium vacation rental management platform. Manage properties, bookings, cleaners, and guests - even offline.",
  "start_url": "/dashboard",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#0a0505",
  "theme_color": "#500000",
  "lang": "en-US",
  "dir": "ltr",
  "categories": ["business", "productivity", "travel", "lifestyle"],
  "prefer_related_applications": false,
