# Right At Home BnB - Mobile Environment Variables
# Copy to .env and fill in values

# API
EXPO_PUBLIC_API_URL=https://rightathome-api.run.app

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=echo-prime-ai.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=echo-prime-ai
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=echo-prime-ai.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=249995513427
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id

# Push Notifications
EXPO_PUBLIC_EAS_PROJECT_ID=your_eas_project_id
