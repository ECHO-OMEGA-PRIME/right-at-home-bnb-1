<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow the app to send Apple Events to other apps -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Allow the app to access the file system -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow the app to make network connections -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Allow the app to be a network server -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Allow printing -->
    <key>com.apple.security.print</key>
    <true/>

    <!-- Allow clipboard access -->
    <key>com.apple.security.temporary-exception.files.home-relative-path.read-write</key>
    <array>
        <string>/Library/Application Support/RightAtHome BnB/</string>
    </array>
</dict>
</plist>
