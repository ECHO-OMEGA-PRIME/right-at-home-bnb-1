# Right at Home BnB - Environment Configuration
# Copy this to .env and fill in your values
#
# SECURITY NOTES:
# - NEVER commit .env files to version control
# - Use strong, unique values for all secrets
# - Rotate secrets regularly (every 90 days)
# - Use a secrets manager in production (Google Secret Manager, Vault)

# ============================================
# DATABASE
# ============================================
# SQLite (development): file:./dev.db
# PostgreSQL (production): postgresql://user:password@host:5432/db?schema=public
DATABASE_URL="file:./dev.db"

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT secret - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# API secret for service-to-service communication
# Generate with: openssl rand -hex 32
API_SECRET_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"

# ============================================
# FIREBASE (Authentication)
# ============================================
FIREBASE_PROJECT_ID="echo-prime-ai"
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Public Firebase config (safe for frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="echo-prime-ai.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="echo-prime-ai"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="echo-prime-ai.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# ============================================
# AI SERVICES
# ============================================
# OpenAI - starts with sk-
OPENAI_API_KEY=""

# Anthropic Claude - starts with sk-ant-
ANTHROPIC_API_KEY=""

# ElevenLabs TTS
ELEVENLABS_API_KEY=""

# ============================================
# API CONFIGURATION
# ============================================
# Development: http://localhost:8000
# Production: https://api.rah-midland.com
NEXT_PUBLIC_API_URL="http://localhost:8000"

# ============================================
# SMART LOCKS
# ============================================
# Schlage
SCHLAGE_API_KEY=""
SCHLAGE_API_SECRET=""

# Yale
YALE_API_KEY=""

# August
AUGUST_API_KEY=""

# ============================================
# EXTERNAL SERVICES
# ============================================
# Google Maps
GOOGLE_MAPS_API_KEY=""

# Twilio (Voice/SMS)
# Account SID starts with AC
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"

# Stripe (Payments)
# Secret key starts with sk_
# Publishable key starts with pk_
# Webhook secret starts with whsec_
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================
# STORAGE — MinIO on ANVIL (replaces Cloudflare R2 per NO-CLOUDFLARE doctrine)
# ============================================
# S3-compatible object store. Drop-in for any code that talks to R2's S3 API.
# Endpoint is the LAN address by default; for Vercel access, expose ANVIL
# via the cloudflared tunnel as e.g. `minio.echo-op.com` and set it there.
MINIO_ENDPOINT="http://192.168.1.96:9000"
MINIO_BUCKET="rah-uploads"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
# Region is irrelevant to MinIO but some S3 SDKs require it set to anything.
MINIO_REGION="us-east-1"

# ============================================
# ECHO SDK GATE + LLM (replaces echo-sdk-gateway.bmcii1976.workers.dev + CF Workers AI)
# ============================================
# Public hostname of the cloudflared tunnel that fronts FORGE :8000 (SDK gate).
# Numerology on echo-op.com already uses this — same tunnel, same key.
ECHO_SDK_GATE="https://sdk1.echo-op.com"
# Sovereign key — value of forge:/home/forge/.echo_sovereign_key (SOVEREIGN_KEY=…).
ECHO_SOVEREIGN_KEY=""
# Capability + model selection for chat/LLM calls. echo.claude.oauth is the
# Max-OAuth gateway ($0 per call); switch to echo.llm.anthropic if you want
# to use a metered API key path instead.
LLM_CAP="echo.claude.oauth"
LLM_MODEL="claude-haiku-4-5-20251001"
# Public hostname of the cloudflared tunnel that fronts FORGE :8001 (RAH backend).
# Used by the apps/web/vercel.json /api/v1/* rewrite.
ECHO_API_BASE="https://api.rah-midland.com"

# ============================================
# OWNERREZ (Channel Manager / PMS)
# ============================================
# Get API token from: OwnerRez > Settings > Advanced Tools > Developer/API Settings
OWNERREZ_EMAIL=""
OWNERREZ_API_TOKEN=""

# ============================================
# TUYA SMART LOCKS
# ============================================
# Get from: https://iot.tuya.com > Cloud > Your Project
TUYA_ACCESS_KEY=""
TUYA_SECRET_KEY=""
TUYA_BASE_URL="https://openapi.tuyaus.com"

# Device IDs per property (from Tuya IoT Platform after linking Smart Life app)
TUYA_LOCK_GARFIELD=""
TUYA_LOCK_CASTLEFORD=""
TUYA_LOCK_LINCOLN_GREEN=""

# ============================================
# DEPLOYMENT
# ============================================
VERCEL_TOKEN=""
GCP_PROJECT_ID="echo-prime-ai"
GCP_REGION="us-central1"

# Environment: development | test | production
NODE_ENV="development"

# ============================================
# CORS (Production)
# ============================================
# Comma-separated list of allowed origins
# Example: https://rah-midland.com,https://www.rah-midland.com
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# ============================================
# SESSION
# ============================================
# Session cookie secret - MUST be at least 32 characters
SESSION_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# Session timeout in seconds (default: 24 hours)
SESSION_TIMEOUT="86400"

# ============================================
# RATE LIMITING
# ============================================
# Max requests per minute for API endpoints
RATE_LIMIT_API="100"

# Max login attempts per 15 minutes
RATE_LIMIT_AUTH="5"
