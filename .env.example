# Right at Home BnB - Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://username:password@localhost:5432/rightathome?schema=public"

# ============================================
# AUTHENTICATION (Firebase)
# ============================================
FIREBASE_PROJECT_ID="echo-prime-ai"
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="echo-prime-ai.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="echo-prime-ai"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="echo-prime-ai.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# ============================================
# AI SERVICES
# ============================================
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
ELEVENLABS_API_KEY=""

# ============================================
# API CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL="http://localhost:8000"
API_SECRET_KEY=""

# ============================================
# SMART LOCKS
# ============================================
SCHLAGE_API_KEY=""
SCHLAGE_API_SECRET=""
YALE_API_KEY=""
AUGUST_API_KEY=""

# ============================================
# EXTERNAL SERVICES
# ============================================
GOOGLE_MAPS_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ============================================
# STORAGE
# ============================================
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
CLOUDFLARE_R2_BUCKET="rightathome-uploads"
CLOUDFLARE_R2_ENDPOINT=""

# ============================================
# DEPLOYMENT
# ============================================
VERCEL_TOKEN=""
GCP_PROJECT_ID="echo-prime-ai"
GCP_REGION="us-central1"
