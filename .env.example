# Right at Home BnB - Environment Configuration
# Copy this to .env and fill in your values
#
# SECURITY NOTES:
# - NEVER commit .env files to version control
# - Use strong, unique values for all secrets
# - Rotate secrets regularly (every 90 days)
# - Use a secrets manager in production (Google Secret Manager, Vault)

# ============================================
# DATABASE
# ============================================
# SQLite (development): file:./dev.db
# PostgreSQL (production): postgresql://user:password@host:5432/db?schema=public
DATABASE_URL="file:./dev.db"

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT secret - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# API secret for service-to-service communication
# Generate with: openssl rand -hex 32
API_SECRET_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"

# ============================================
# FIREBASE (Authentication)
# ============================================
FIREBASE_PROJECT_ID="echo-prime-ai"
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Public Firebase config (safe for frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="echo-prime-ai.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="echo-prime-ai"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="echo-prime-ai.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# ============================================
# AI SERVICES
# ============================================
# OpenAI - starts with sk-
OPENAI_API_KEY=""

# Anthropic Claude - starts with sk-ant-
ANTHROPIC_API_KEY=""

# ElevenLabs TTS
ELEVENLABS_API_KEY=""

# ============================================
# API CONFIGURATION
# ============================================
# Development: http://localhost:8000
# Production: https://api.rightathomebnb.com
NEXT_PUBLIC_API_URL="http://localhost:8000"

# ============================================
# SMART LOCKS
# ============================================
# Schlage
SCHLAGE_API_KEY=""
SCHLAGE_API_SECRET=""

# Yale
YALE_API_KEY=""

# August
AUGUST_API_KEY=""

# ============================================
# EXTERNAL SERVICES
# ============================================
# Google Maps
GOOGLE_MAPS_API_KEY=""

# Twilio (Voice/SMS)
# Account SID starts with AC
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"

# Stripe (Payments)
# Secret key starts with sk_
# Publishable key starts with pk_
# Webhook secret starts with whsec_
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================
# STORAGE
# ============================================
# Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
CLOUDFLARE_R2_BUCKET="rightathome-uploads"
CLOUDFLARE_R2_ENDPOINT=""

# ============================================
# DEPLOYMENT
# ============================================
VERCEL_TOKEN=""
GCP_PROJECT_ID="echo-prime-ai"
GCP_REGION="us-central1"

# Environment: development | test | production
NODE_ENV="development"

# ============================================
# CORS (Production)
# ============================================
# Comma-separated list of allowed origins
# Example: https://rightathomebnb.com,https://www.rightathomebnb.com
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# ============================================
# SESSION
# ============================================
# Session cookie secret - MUST be at least 32 characters
SESSION_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# Session timeout in seconds (default: 24 hours)
SESSION_TIMEOUT="86400"

# ============================================
# RATE LIMITING
# ============================================
# Max requests per minute for API endpoints
RATE_LIMIT_API="100"

# Max login attempts per 15 minutes
RATE_LIMIT_AUTH="5"
