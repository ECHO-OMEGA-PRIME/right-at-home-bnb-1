// Right at Home BnB - Prisma Schema
// Steven Palma | Midland, TX | 22 Properties
// Complete database schema for property management system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  phone         String?
  avatarUrl     String?
  role          UserRole  @default(GUEST)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  cleaningJobs  CleaningJob[]
  expenses      Expense[]
  approvedMsgs  Message[]     @relation("ApprovedBy")

  @@index([email])
  @@index([role])
}

enum UserRole {
  ADMIN
  CLEANER
  GUEST
}

// ============================================
// PROPERTIES
// ============================================

model Property {
  id              String    @id @default(cuid())
  name            String
  address         String
  city            String    @default("Midland")
  state           String    @default("TX")
  zipCode         String?
  latitude        Float?
  longitude       Float?

  // Property Details
  bedrooms        Int
  bathrooms       Float
  maxGuests       Int
  squareFeet      Int?
  propertyType    PropertyType @default(HOUSE)

  // Amenities & Info
  amenities       Json?     // Array of amenity strings
  wifiNetwork     String?
  wifiPassword    String?
  parkingInfo     String?
  checkInInstr    String?   @db.Text
  checkOutInstr   String?   @db.Text
  houseRules      String?   @db.Text

  // Cleaning
  cleaningChecklist Json?   // Array of checklist items

  // Pricing
  nightlyRate     Decimal   @db.Decimal(10, 2)
  cleaningFee     Decimal?  @db.Decimal(10, 2)
  securityDeposit Decimal?  @db.Decimal(10, 2)

  // External IDs
  airbnbId        String?
  vrboId          String?

  // Status
  status          PropertyStatus @default(ACTIVE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  bookings        Booking[]
  cleaningJobs    CleaningJob[]
  smartLock       SmartLock?
  expenses        Expense[]
  photos          PropertyPhoto[]

  @@index([status])
  @@index([city])
}

model PropertyPhoto {
  id          String    @id @default(cuid())
  propertyId  String
  url         String
  caption     String?
  isPrimary   Boolean   @default(false)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

enum PropertyType {
  HOUSE
  APARTMENT
  CONDO
  TOWNHOUSE
  CABIN
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// ============================================
// GUESTS & CRM
// ============================================

model Guest {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  phone         String?

  // Source
  platform      Platform  @default(DIRECT)
  platformId    String?   // External booking platform ID

  // CRM Data
  firstStay     DateTime?
  lastStay      DateTime?
  totalStays    Int       @default(0)
  totalSpent    Decimal   @default(0) @db.Decimal(10, 2)
  avgRating     Float?

  // Tags & Preferences
  tags          Json?     // Array of tags: ["VIP", "Pet Owner", "Business"]
  notes         String?   @db.Text
  preferences   Json?     // Guest preferences object

  // VIP Status
  isVip         Boolean   @default(false)
  vipTier       VipTier?

  // Special Dates
  birthday      DateTime?
  anniversary   DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  bookings      Booking[]
  messages      Message[]
  conciergeQueries ConciergeQuery[]

  @@index([email])
  @@index([isVip])
}

enum Platform {
  AIRBNB
  VRBO
  BOOKING
  DIRECT
  OTHER
}

enum VipTier {
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

// ============================================
// BOOKINGS
// ============================================

model Booking {
  id            String    @id @default(cuid())
  propertyId    String
  guestId       String

  // Dates
  checkIn       DateTime
  checkOut      DateTime

  // Details
  guestCount    Int       @default(1)
  platform      Platform  @default(DIRECT)
  confirmCode   String?   // Platform confirmation code

  // Pricing
  nightlyRate   Decimal   @db.Decimal(10, 2)
  totalNights   Int
  subtotal      Decimal   @db.Decimal(10, 2)
  cleaningFee   Decimal?  @db.Decimal(10, 2)
  serviceFee    Decimal?  @db.Decimal(10, 2)
  taxes         Decimal?  @db.Decimal(10, 2)
  totalPrice    Decimal   @db.Decimal(10, 2)

  // Access
  accessCode    String?   // Smart lock code
  codeExpiresAt DateTime?

  // Status
  status        BookingStatus @default(CONFIRMED)
  specialReqs   String?   @db.Text
  internalNotes String?   @db.Text

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  property      Property  @relation(fields: [propertyId], references: [id])
  guest         Guest     @relation(fields: [guestId], references: [id])
  cleaningJob   CleaningJob?
  messages      Message[]

  @@index([propertyId])
  @@index([guestId])
  @@index([checkIn])
  @@index([checkOut])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

// ============================================
// CLEANING & CREW
// ============================================

model CleaningJob {
  id            String    @id @default(cuid())
  propertyId    String
  cleanerId     String?
  bookingId     String?   @unique

  // Scheduling
  scheduledAt   DateTime
  startedAt     DateTime?
  completedAt   DateTime?

  // Type
  jobType       CleaningType @default(TURNOVER)

  // Status
  status        CleaningStatus @default(SCHEDULED)

  // GPS Verification
  checkInLat    Float?
  checkInLng    Float?
  checkOutLat   Float?
  checkOutLng   Float?

  // Checklist & Photos
  checklistProgress Json? // { itemId: boolean }
  photos        Json?     // Array of photo URLs

  // Quality
  score         Int?      // AI-generated quality score 1-100
  scoreFeedback String?   @db.Text

  // Notes
  notes         String?   @db.Text
  issues        String?   @db.Text

  // Duration
  durationMins  Int?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  property      Property  @relation(fields: [propertyId], references: [id])
  cleaner       User?     @relation(fields: [cleanerId], references: [id])
  booking       Booking?  @relation(fields: [bookingId], references: [id])

  @@index([propertyId])
  @@index([cleanerId])
  @@index([status])
  @@index([scheduledAt])
}

enum CleaningType {
  TURNOVER
  DEEP_CLEAN
  INSPECTION
  MAINTENANCE
}

enum CleaningStatus {
  SCHEDULED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ISSUE_REPORTED
}

// ============================================
// SMART LOCKS
// ============================================

model SmartLock {
  id            String    @id @default(cuid())
  propertyId    String    @unique

  // Device Info
  brand         LockBrand
  model         String?
  deviceId      String    // External device identifier
  serialNumber  String?

  // Current State
  currentCode   String?
  codeExpiresAt DateTime?
  batteryLevel  Int?      // 0-100
  lastActivity  DateTime?
  isOnline      Boolean   @default(true)

  // Access Log
  accessLog     Json?     // Array of access events

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  property      Property  @relation(fields: [propertyId], references: [id])

  @@index([brand])
}

enum LockBrand {
  SCHLAGE
  YALE
  AUGUST
  KWIKSET
  OTHER
}

// ============================================
// MESSAGING
// ============================================

model Message {
  id            String    @id @default(cuid())
  guestId       String
  bookingId     String?

  // Message Details
  type          MessageType
  channel       MessageChannel @default(EMAIL)
  subject       String?
  body          String    @db.Text

  // Status
  status        MessageStatus @default(DRAFT)

  // Scheduling
  scheduledFor  DateTime?
  sentAt        DateTime?

  // Approval
  approvedBy    String?
  approvedAt    DateTime?

  // AI Analysis
  sentiment     Sentiment?
  sentimentScore Float?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  guest         Guest     @relation(fields: [guestId], references: [id])
  booking       Booking?  @relation(fields: [bookingId], references: [id])
  approver      User?     @relation("ApprovedBy", fields: [approvedBy], references: [id])

  @@index([guestId])
  @@index([bookingId])
  @@index([status])
  @@index([type])
}

enum MessageType {
  BOOKING_CONFIRM
  PRE_ARRIVAL
  CHECK_IN
  DURING_STAY
  CHECK_OUT
  POST_STAY
  REVIEW_REQUEST
  CUSTOM
}

enum MessageChannel {
  EMAIL
  SMS
  WHATSAPP
  APP_NOTIFICATION
}

enum MessageStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  SENT
  DELIVERED
  FAILED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

// ============================================
// FINANCES
// ============================================

model Expense {
  id            String    @id @default(cuid())
  propertyId    String
  createdById   String?

  // Expense Details
  category      ExpenseCategory
  subcategory   String?
  amount        Decimal   @db.Decimal(10, 2)
  description   String
  vendor        String?

  // Date
  date          DateTime

  // Receipt
  receiptUrl    String?

  // Tax
  isTaxDeductible Boolean @default(true)
  taxCategory   String?

  // Status
  status        ExpenseStatus @default(PENDING)

  // Notes
  notes         String?   @db.Text

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  property      Property  @relation(fields: [propertyId], references: [id])
  createdBy     User?     @relation(fields: [createdById], references: [id])

  @@index([propertyId])
  @@index([category])
  @@index([date])
}

enum ExpenseCategory {
  CLEANING
  MAINTENANCE
  UTILITIES
  SUPPLIES
  FURNITURE
  APPLIANCES
  INSURANCE
  TAXES
  MARKETING
  SOFTWARE
  PROFESSIONAL_FEES
  MORTGAGE
  HOA
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// ============================================
// AI CONCIERGE
// ============================================

model ConciergeQuery {
  id            String    @id @default(cuid())
  guestId       String?
  propertyId    String?

  // Query & Response
  query         String    @db.Text
  response      String    @db.Text

  // Classification
  category      ConciergeCategory?
  intent        String?

  // Quality
  wasHelpful    Boolean?
  rating        Int?      // 1-5

  // Voice
  voiceUsed     Boolean   @default(false)
  audioUrl      String?

  createdAt     DateTime  @default(now())

  // Relations
  guest         Guest?    @relation(fields: [guestId], references: [id])

  @@index([guestId])
  @@index([category])
  @@index([createdAt])
}

enum ConciergeCategory {
  PROPERTY_INFO
  DIRECTIONS
  RESTAURANTS
  ACTIVITIES
  EMERGENCY
  CHECKOUT
  LATE_CHECKOUT
  WIFI
  AMENITIES
  LOCAL_EVENTS
  TRANSPORTATION
  OTHER
}

// ============================================
// SYSTEM & AUDIT
// ============================================

model AuditLog {
  id            String    @id @default(cuid())
  userId        String?
  action        String
  entity        String    // Table name
  entityId      String?
  oldValues     Json?
  newValues     Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model Setting {
  id            String    @id @default(cuid())
  key           String    @unique
  value         Json
  description   String?
  updatedAt     DateTime  @updatedAt
}
