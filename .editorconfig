# EditorConfig — https://editorconfig.org
# Maintained by Echo Prime Tech LLC publisher fleet.
root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,json,css,scss,html,md,yml,yaml}]
indent_size = 2

[*.{py,sh}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.prisma]
indent_size = 2
