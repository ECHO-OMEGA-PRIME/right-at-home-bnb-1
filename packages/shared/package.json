{
  "name": "@rightathome/shared",
  "version": "1.0.0",
  "description": "Shared types, sync, and utilities for Right at Home BNB",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./sync": {
      "import": "./dist/sync/index.mjs",
      "require": "./dist/sync/index.js",
      "types": "./dist/sync/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/sync/hooks.mjs",
      "require": "./dist/sync/hooks.js",
      "types": "./dist/sync/hooks.d.ts"
    },
    "./firebase": {
      "import": "./dist/firebase/index.mjs",
      "require": "./dist/firebase/index.js",
      "types": "./dist/firebase/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/index.mjs",
      "require": "./dist/api/index.js",
      "types": "./dist/api/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/types/index.ts src/sync/index.ts src/sync/hooks.ts src/firebase/index.ts src/api/index.ts --format cjs,esm --dts",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "firebase": "^10.7.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "rightathome",
    "bnb",
    "property-management",
    "sync"
  ],
  "license": "PROPRIETARY"
}
