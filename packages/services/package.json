{
  "name": "@rightathome/services",
  "version": "1.0.0",
  "description": "Right at Home BnB - Core Services (Logging, Caching, Error Handling, Rate Limiting)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./logger": {
      "import": "./dist/logger.mjs",
      "require": "./dist/logger.js",
      "types": "./dist/logger.d.ts"
    },
    "./cache": {
      "import": "./dist/cache.mjs",
      "require": "./dist/cache.js",
      "types": "./dist/cache.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.mjs",
      "require": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    },
    "./rate-limiter": {
      "import": "./dist/rate-limiter.mjs",
      "require": "./dist/rate-limiter.js",
      "types": "./dist/rate-limiter.d.ts"
    },
    "./api": {
      "import": "./dist/api.mjs",
      "require": "./dist/api.js",
      "types": "./dist/api.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/logger.ts src/cache.ts src/errors.ts src/rate-limiter.ts src/api.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/logger.ts src/cache.ts src/errors.ts src/rate-limiter.ts src/api.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lru-cache": "^10.0.0"
  },
  "devDependencies": {
    "tsup": "^7.2.0",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  }
}
